---
// Assets
import Kicker from "@/components/assets/Kicker.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const data = [
  {
    title: "One missed appointment",
    subtitle:
      "The first legal step often depends on one exact date.",
      
  },

  {
    title: "Wrong insurance choice",
    subtitle:
      "Not every policy accepted online is accepted by immigration.",
  },
  {
    title: "Silent delays",
    subtitle:
      "One missing local registration can block the next process.",
  },
  
];
---

<section>
  <Wrapper variant="standard" class="py-8">
    <div class="p-8 lg:px-20 lg:py-12 bg-blue-100">
      <div
        class="grid gap-4 lg:gap-8 grid-cols-1 lg:grid-cols-3 lg:items-start"
      >
        <div class="text-balance lg:sticky lg:top-24 lg:order-last">
          <div>
            <Kicker
              number="02"
              text="WHERE DELAYS BEGINS"
              colorClass="text-base-900"
            />
            <Text
              tag="h2"
              variant="textXL"
              class="text-accent-950 font-display font-medium mt-12"
            >
              Three documents families often underestimate
            </Text>
          </div>
          <Text tag="p" variant="textSM" class="mt-2 text-base-600">
            <!--If You Will Be Living In Madrid As A Student You Might Need This-->
          </Text>
        </div>
        <div
          class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-1 lg:col-span-2 divide-y divide-blue-200"
        >
          {
            data.map((item) => (
              <div>
                <div class="relative flex flex-col justify-start  pb-8 grid grid-cols-1 gap-2 ">
                  <Text
                    tag="h3"
                    variant="textLG"
                    class=" text-base-900 font-display tracking-tight"
                  >
                    {item.title}
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class=" text-base-900/60 text-balance "
                  >
                    {item.subtitle}
                  </Text>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
