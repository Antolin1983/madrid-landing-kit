---
// Assets
import Kicker from "@/components/assets/Kicker.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const data = [
  {
    title: "Missed deadlines",
    subtitle: "One missed appointment can affect the next legal step.",
  },
  {
    title: "Wrong documents",
    subtitle: "Many papers look valid until they are rejected in person.",
  },
  {
    title: "Silent delays",
    subtitle: "Sometimes nobody tells you something is missing until it is already late.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-8">
    <div class="p-8 lg:p-20 bg-accent-100">
      <div
        class="grid gap-4 lg:gap-8 grid-cols-1 lg:grid-cols-3 lg:items-start"
      >
        <div class="text-balance lg:sticky lg:top-24">
          <div>
            <Kicker
              number="01"
              text="What parents discover too late"
              colorClass="text-base-900"
            />
            <Text
              tag="h2"
              variant="textXL"
              class="text-accent-950 font-display font-medium mt-12"
            >
              Three small mistakes can delay documents, appointments or legal steps much more than most families expect
            </Text>
          </div>
          <Text tag="p" variant="textSM" class="mt-2 text-base-600">
            <!-- Madrid is known for its academic excellence, hosting internationally
            renowned educational institutions that offer innovative programs in
            various disciplines.-->
          </Text>
        </div>
        <div
          class=" gap-8 flex flex-col lg:col-span-2 divide-y divide-accent-200"
        >
          {
            data.map((item) => (
              <div>
                <div class="relative flex flex-col justify-start  pb-8 flex flex-col gap-2 ">
                  <Text
                    tag="h3"
                    variant="textLG"
                    class=" text-base-900 font-display tracking-tight"
                  >
                    {item.title}
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class=" text-base-900/60 text-balance "
                  >
                    {item.subtitle}
                  </Text>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
